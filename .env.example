# Database
DATABASE_URI=postgresql://payload:payload@localhost:5432/popelec

# Payload
PAYLOAD_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# Server
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend or SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_...
SMTP_FROM=noreply@popelec.fr

# Seafile (optional — omit SEAFILE_URL to disable)
SEAFILE_URL=http://seafile:80
NEXT_PUBLIC_SEAFILE_URL=https://files.popelec.fr
SEAFILE_ADMIN_EMAIL=admin@popelec.fr
SEAFILE_ADMIN_PASSWORD=...
SEAFILE_ADMIN_TOKEN=...
SEAFILE_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_RANDOM_STRING
SEAFILE_MYSQL_ROOT_PASSWORD=...

# Supplier import (admin → "Importer fournisseur" view)
# Library where YAML manifests + image folders live; image paths in the YAML
# are interpreted relative to that library's root.
SEAFILE_IMPORT_LIBRARY_ID=
SEAFILE_IMPORT_MANIFEST_DIR=/manifests
